{
  "name": "umzug-modern",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:setup": "./dev-setup.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "docker:build": "docker build -t asam-abd-app .",
    "docker:run": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "analyze": "ANALYZE=true next build",
    "security:audit": "yarn audit --level moderate",
    "security:fix": "yarn audit fix",
    "deps:update": "yarn upgrade-interactive --latest",
    "prod:build": "NODE_ENV=production yarn build",
    "prod:start": "NODE_ENV=production yarn start"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.19",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^6.8.2",
    "aos": "^2.3.4",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.4.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "critters": "^0.0.25",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "next": "14.2.30",
    "next-auth": "^4.24.11",
    "nodemailer": "^7.0.5",
    "prisma": "^6.8.2",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "react-intersection-observer": "^9.8.1",
    "sharp": "^0.33.2",
    "swiper": "^11.2.10",
    "tailwind-merge": "^2.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.30",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/aos": "^3.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "10.4.14",
    "eslint": "^8",
    "eslint-config-next": "14.2.30",
    "postcss": "8.4.31",
    "prisma": "^6.8.2",
    "tailwindcss": "3.3.0",
    "typescript": "^5"
  }
}
